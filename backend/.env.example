# ── Environment ────────────────────────────────────────────────────
# dev = SQLite, auto-create schema, auth bypassed
# production = PostgreSQL, Alembic migrations, auth required
ENV=dev

# ── Database ───────────────────────────────────────────────────────
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://nse_trader:nse_trader@localhost:5432/nse_trader
# DATABASE_URL_SYNC=postgresql+psycopg2://nse_trader:nse_trader@localhost:5432/nse_trader

# SQLite (local dev)
DATABASE_URL=sqlite+aiosqlite:///./nse_trader_dev.db
DATABASE_URL_SYNC=sqlite:///./nse_trader_dev.db

# ── Historical Data Thresholds ─────────────────────────────────────
MIN_OHLCV_SESSIONS=60
MIN_ASI_SESSIONS=60
OHLCV_STALENESS_DAYS=5

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Security ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_HEAVY=30/minute
RATE_LIMIT_WRITE=20/minute
