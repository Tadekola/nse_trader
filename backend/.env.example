# Backend API Settings
# Set a secret key for production use (e.g., JWT signing)
# SECRET_KEY=your_very_secret_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password # Uncomment if Redis requires authentication

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest # Default user, change for production
RABBITMQ_PASSWORD=guest # Default password, change for production
RABBITMQ_VHOST=/

# External API Configuration (Replace with actual endpoints/keys)
NGX_API_BASE_URL=http://localhost:8001/ngx-sim # Example: URL for NGX data simulator
# TRADINGVIEW_API_KEY=your_tradingview_api_key # Example: If needed

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
